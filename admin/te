<?php
if (isset($_POST['upload'])) {
    $uploadDir = '../files/';
    
    if (!is_dir($uploadDir)) {
        mkdir($uploadDir, 0777, true);
    }

    // basename() krusial untuk mencegah Path Traversal inject nama file
    $fileName = basename($_FILES['uploadedfile']['name']);
    $targetPath = $uploadDir . $fileName;
    $fileExtension = strtolower(pathinfo($targetPath, PATHINFO_EXTENSION));

    // Proteksi RCE: Tolak file yang bisa dieksekusi di server
    $blacklisted = ['php', 'phtml', 'php3', 'php4', 'php5', 'phps', 'htaccess', 'js', 'html'];
    if (in_array($fileExtension, $blacklisted)) {
        echo "<script>alert('Error: Ekstensi file dilarang demi keamanan server!'); window.location.href='index.php';</script>";
        exit;
    }

    // Validasi Sisi Server untuk Ukuran (Double Check JS)
    if ($_FILES['uploadedfile']['size'] > 100 * 1024 * 1024) {
        echo "<script>alert('Error: File melebihi batas 100MB!'); window.location.href='index.php';</script>";
        exit;
    }

    if (move_uploaded_file($_FILES['uploadedfile']['tmp_name'], $targetPath)) {
        echo "<script>alert('File berhasil diupload!'); window.location.href='index.php';</script>";
    } else {
        echo "<script>alert('Gagal memproses upload file.'); window.location.href='index.php';</script>";
    }
} else {
    header("Location: index.php");
    exit;
}


// ==========================================
// FILE 3: download.php
// ==========================================
<?php
if (isset($_GET['id'])) {
    $uploadDir = '../files/';
    $fileName = basename($_GET['id']); // Mencegah download file luar sistem (?id=../../etc/passwd)
    $filePath = $uploadDir . $fileName;

    if (file_exists($filePath) && is_file($filePath)) {
        // Bersihkan output buffer agar file unduhan tidak korup
        if (ob_get_level()) {
            ob_end_clean();
        }

        // Header standar proses download file aman
        header('Content-Description: File Transfer');
        header('Content-Type: application/octet-stream');
        header('Content-Disposition: attachment; filename="' . $fileName . '"');
        header('Expires: 0');
        header('Cache-Control: must-revalidate');
        header('Pragma: public');
        header('Content-Length: ' . filesize($filePath));
        
        readfile($filePath);
        exit;
    } else {
        echo "<script>alert('File tidak ditemukan!'); window.location.href='index.php';</script>";
        exit;
    }
} else {
    header("Location: index.php");
    exit;
}


// ==========================================
// FILE 4: hapus.php
// ==========================================
<?php
if (isset($_GET['id'])) {
    $uploadDir = '../files/';
    $fileName = basename($_GET['id']); // Mencegah manipulasi hapus file krusial (?id=../index.php)
    $filePath = $uploadDir . $fileName;

    if (file_exists($filePath) && is_file($filePath)) {
        if (unlink($filePath)) {
            echo "<script>alert('File berhasil dihapus!'); window.location.href='index.php';</script>";
        } else {
            echo "<script>alert('Gagal menghapus file.'); window.location.href='index.php';</script>";
        }
        exit;
    } else {
        echo "<script>alert('File tidak ditemukan atau sudah terhapus!'); window.location.href='index.php';</script>";
        exit;
    }
} else {
    header("Location: index.php");
    exit;
}
